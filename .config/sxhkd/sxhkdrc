super + control + shift + r
  resx

super + Return
  alacritty

super + F{2,3,4,5}
  {chromium,zeditor,pcmanfm,terminal -e mus}

super + shift + control + alt + {2,3,4,5}
  {chromium,zeditor,pcmanfm,terminal -e mus}

super + v
  copyq show

super + ctrl + {x,m,c,b,n,s,q,t,z}
  {xkill, pavucontrol, xcolor | xsel -b, book, notion-app; notion-calendar-electron, ocr, qbar, ocr en, boomer}

super + shift + {space,s,a,b,c,d,p,g,o,w,y,j,i}
  {rofi -show drun, power-menu, auto-menu, changelog-menu, c-menu, s-menu, p-menu, github-menu, open-menu, wifi-menu, youtube-menu, dl-menu, screen-menu}

super + shift + ctrl + alt + {space,s,a,b,c,d,p,g,o,w,y,j,i}
  {rofi -show drun, power-menu, auto-menu, changelog-menu, c-menu, s-menu, p-menu, github-menu, open-menu, wifi-menu, youtube-menu, dl-menu, screen-menu}

super + shift + t
  flyterm

XF86Audio{LowerVolume,RaiseVolume}
  pactl set-sink-volume @DEFAULT_SINK@ {-10%, +10%}

XF86AudioMute
  pactl set-sink-mute @DEFAULT_SINK@ toggle

XF86AudioPrev
    playerctl previous

XF86AudioNext
    playerctl next

XF86AudioPlay
    playerctl play-pause

XF86AudioStop
    playerctl stop

XF86MonBrightness{Down,Up}
  light {-U,-A} 5

super + control + p
  flameshot gui
