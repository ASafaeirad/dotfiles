#!/usr/bin/env bash
source "$HOME/.local/bin/menus/_menu"
shopt -s nullglob globstar

SCR_IMG=$(mktemp)
echo $SCR_IMG
trap "rm $SCR_IMG*" EXIT

scrot --line mode=edge -s $SCR_IMG.png -q 100
OTP=$(zbarimg $SCR_IMG.png)
OTP=${OTP#*:}

if [[ -z $OTP ]]; then
  exit 0
fi

if [[ $OTP != otpauth://* ]]; then
  notify-send "Wrong QR code" "Please scan the QR code for OTP" -u critical --expire-time=5000
  exit 1
fi

PASS_DIR=${PASSWORD_STORE_DIR-~/.password-store}
PASS_FILES=("$PASS_DIR"/**/*.gpg)
RELATIVE_FILENAMES=("${PASS_FILES[@]#"$PASS_DIR"/}")
LIST=("${RELATIVE_FILENAMES[@]%.gpg}" "otp")
PASSWORD=$(print_list "${LIST[@]}" | _dmenu -p "Password" "$@")

if [[ -z $PASSWORD ]]; then
  exit 0
fi

echo "$OTP" | pass otp append $PASSWORD

notify-send "OTP for $PASSWORD has been added to the password store" -u normal --expire-time=5000 --

scopy "$(pass otp show $PASSWORD)"
