#!/usr/bin/env bash
set -e

sudo systemctl start bluetooth.service

while true; do
  if [ "$(systemctl is-active bluetooth.service)" = "active" ]; then
    break
  fi

  sleep 1
done

JBL_MAC="F8:5C:7D:36:0C:7C"

bluetoothctl scan on
bluetoothctl disconnect "$JBL_MAC"
bluetoothctl connect "$JBL_MAC"
