#!/usr/bin/env bash

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
source "$SCRIPT_DIR/_menu"

DIR="$HOME/devs"
LIST=$(ls "$DIR")

SELECTED=$(print_list "${LIST[@]}" | rofi -dmenu -i -p "Dev")
SELECTED="${DIR}/${SELECTED}"

if [[ -d "${SELECTED}" ]]; then
  code "${SELECTED}"
fi
