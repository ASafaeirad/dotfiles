#!/usr/bin/env bash
# regionshot <output.png>
# Interactive region screenshot. Works on both sessions:
#   Wayland -> grim + slurp   |   X11 -> scrot
# Added for the Hyprland migration so ocr/qbar keep working under both.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
source "$SCRIPT_DIR/lib/common.sh"

out="${1:-}"
[ -z "$out" ] && die "usage: regionshot <output.png>"

if [ "${XDG_SESSION_TYPE:-}" = "wayland" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
  grim -g "$(slurp)" "$out"
else
  scrot --line mode=edge -s "$out" -q 100
fi
