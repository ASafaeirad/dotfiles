#!/usr/bin/env bash

usage() {
  echo "Usage: port [port-number]" >&2
  exit "${1:-1}"
}

list_open_ports() {
  if command -v ss >/dev/null 2>&1; then
    sudo ss -tulpn 2>/dev/null || ss -tulpn
  elif command -v netstat >/dev/null 2>&1; then
    sudo netstat -tulpn 2>/dev/null || netstat -tulpn
  else
    echo "Neither ss nor netstat is available." >&2
    exit 127
  fi
}

if [[ "${1:-}" = "-h" || "${1:-}" = "--help" ]]; then
  usage 0
fi

if [[ -z "${1:-}" ]]; then
  list_open_ports
  exit 0
fi

PORT="${1#:}"
if ! [[ "$PORT" =~ ^[0-9]+$ ]] || ((PORT < 1 || PORT > 65535)); then
  echo "Invalid port: $1 (expected 1-65535)" >&2
  exit 1
fi

port_re=":${PORT}([^0-9]|\$)"

collect_pids() {
  {
    if command -v ss >/dev/null 2>&1; then
      sudo ss -tulpn -H 2>/dev/null | grep -E "$port_re" | grep -oE 'pid=[0-9]+' | cut -d= -f2 || true
    else
      sudo netstat -tulpn 2>/dev/null | grep -E "$port_re" | awk '{print $NF}' | grep -oE '^[0-9]+' || true
    fi
    if command -v lsof >/dev/null 2>&1; then
      sudo lsof -i ":${PORT}" -P -n -t 2>/dev/null || true
    fi
  } | grep -E '^[0-9]+$' | sort -un
}

mapfile -t pids < <(collect_pids)
if ((${#pids[@]})); then
  pid_csv=$(
    IFS=,
    echo "${pids[*]}"
  )
  if ! ps -p "$pid_csv" -o pid,ppid,user,group,etime,cmd 2>/dev/null; then
    echo "no matching rows; processes may have exited since discovery" >&2
  fi
else
  echo "no process PIDs resolved for port ${PORT}" >&2
fi
