#!/usr/bin/env bash

if [[ -z "${1:-}" ]]; then
  echo "Usage: create-openvpn <host>" >&2
  exit 1
fi

host=$1
remote_config=${OPENVPN_REMOTE_CONFIG:-/root/iran.ovpn}
local_config=${OPENVPN_LOCAL_CONFIG:-$HOME/desktop/iran.ovpn}

printf 'Run a remote OpenVPN installer on root@%s? [y/N] ' "$host" >&2
read -r answer
[[ "$answer" =~ ^[Yy]$|^[Yy][Ee][Ss]$ ]] || exit 1

ssh -t "root@$host" "curl -O https://raw.githubusercontent.com/angristan/openvpn-install/master/openvpn-install.sh; chmod +x openvpn-install.sh; sudo ./openvpn-install.sh"
scp "root@$host:$remote_config" "$local_config"
